   "source": [
    "# Chart 1: Total Sales by Category\n",
    "category_sales = df.groupby('Category')['Sales'].sum().sort_values(ascending=False)\n",
    "\n",
    "plt.figure()\n",
    "bars = sns.barplot(x=category_sales.index, y=category_sales.values, \n",
    "                   hue=category_sales.index, palette='Blues_d', legend=False)\n",
    "\n",
    "# Add value labels on bars\n",
    "for bar, value in zip(bars.patches, category_sales.values):\n",
    "    bars.text(bar.get_x() + bar.get_width()/2, \n",
    "              bar.get_height() + 5000,\n",
    "              f'${value:,.0f}', \n",
    "              ha='center', fontsize=11)\n",
    "\n",
    "plt.title('Total Sales by Category', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Category', fontsize=12)\n",
    "plt.ylabel('Total Sales ($)', fontsize=12)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/01_sales_by_category.png', dpi=150)\n",
    "plt.show()"
   ]
  },
