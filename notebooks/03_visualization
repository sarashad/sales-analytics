    "plt.figure()\n",
    "bars = sns.barplot(x=sub_sales.values, y=sub_sales.index,\n",
    "                   hue=sub_sales.index, palette='Blues_d', legend=False)\n",
    "\n",
    "for bar, value in zip(bars.patches, sub_sales.values):\n",
    "    bars.text(bar.get_width() + 1000, \n",
    "              bar.get_y() + bar.get_height()/2,\n",
    "              f'${value:,.0f}',\n",
    "              va='center', fontsize=10)\n",
    "\n",
    "plt.title('Top 10 Sub-Categories by Sales', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Total Sales ($)', fontsize=12)\n",
    "plt.ylabel('Sub-Category', fontsize=12)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/04_top_subcategories.png', dpi=150)\n",
    "plt.show()"
   ]
