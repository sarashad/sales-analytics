    "# Chart 3: Sales by Region\n",
    "region_sales = df.groupby('Region')['Sales'].sum().sort_values(ascending=False)\n",
    "\n",
    "plt.figure()\n",
    "colors = ['#2196F3', '#42A5F5', '#90CAF9', '#BBDEFB']\n",
    "wedges, texts, autotexts = plt.pie(region_sales.values, \n",
    "                                    labels=region_sales.index,\n",
    "                                    autopct='%1.1f%%',\n",
    "                                    colors=colors,\n",
    "                                    startangle=90)\n",
    "\n",
    "for text in autotexts:\n",
    "    text.set_fontsize(12)\n",
    "    text.set_fontweight('bold')\n",
    "\n",
    "plt.title('Sales Distribution by Region', fontsize=16, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/03_sales_by_region.png', dpi=150)\n",
    "plt.show()"
   ]
